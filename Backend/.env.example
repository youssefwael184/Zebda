# ============================================================
# Goal Guesser — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL="mysql://root@127.0.0.1:3306/zebda"
# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=15m

# Refresh Token
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_change_this_in_production
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS — your React dev server
CLIENT_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
